# ═══════════════════════════════════════════════════════════════
#  AWS Elastic Beanstalk — Flask App Configuration
# ═══════════════════════════════════════════════════════════════
# Environment variables are set via EB Console or `eb setenv`
# DATABASE_URL=postgres://user:pass@rds-host:5432/adaptiveauth
# REDIS_URL=redis://elasticache-host:6379/0
# S3_BUCKET=adaptive-auth-models
# SECRET_KEY=your-production-secret-key

option_settings:
  aws:elasticbeanstalk:application:environment:
    FLASK_ENV: "production"
  aws:elasticbeanstalk:environment:
    EnvironmentType: "SingleInstance"
  aws:autoscaling:launchconfiguration:
    InstanceType: "t3.micro"
